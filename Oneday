<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>💰 บัญชีรายรับรายจ่าย</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #0f0f14; color: #e6edf3; font-family: 'Inter', system-ui, sans-serif; }
  select option { background: #1a1a24; color: #e6edf3; }
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-thumb { background: #30363d; border-radius: 3px; }
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const { useState, useMemo, useEffect } = React;

const INCOME_CATS = ["เงินเดือน","ธุรกิจ","การลงทุน","โบนัส","อื่นๆ"];
const EXPENSE_CATS = ["อาหาร","ค่าเดินทาง","ที่พัก","สุขภาพ","บันเทิง","ช้อปปิ้ง","ค่าน้ำค่าไฟ","อื่นๆ"];
const MONTHS_TH = ["มกราคม","กุมภาพันธ์","มีนาคม","เมษายน","พฤษภาคม","มิถุนายน","กรกฎาคม","สิงหาคม","กันยายน","ตุลาคม","พฤศจิกายน","ธันวาคม"];

const initialForm = {
  date: new Date().toISOString().split("T")[0],
  type: "expense",
  category: "อาหาร",
  amount: "",
  note: "",
};

function App() {
  const today = new Date();
  const [records, setRecords] = useState(() => {
    try { return JSON.parse(localStorage.getItem("budget_records") || "[]"); } catch { return []; }
  });
  const [form, setForm] = useState(initialForm);
  const [showForm, setShowForm] = useState(false);
  const [tab, setTab] = useState("list");
  const [viewMonth, setViewMonth] = useState(today.getMonth());
  const [viewYear, setViewYear] = useState(today.getFullYear());
  const [toast, setToast] = useState("");

  useEffect(() => { localStorage.setItem("budget_records", JSON.stringify(records)); }, [records]);
  const showToast = msg => { setToast(msg); setTimeout(() => setToast(""), 2500); };

  const monthRecords = useMemo(() => records.filter(r => {
    const d = new Date(r.date);
    return d.getMonth() === viewMonth && d.getFullYear() === viewYear;
  }).sort((a,b) => b.date.localeCompare(a.date)), [records, viewMonth, viewYear]);

  const totalIncome = useMemo(() => monthRecords.filter(r=>r.type==="income").reduce((s,r)=>s+parseFloat(r.amount||0),0), [monthRecords]);
  const totalExpense = useMemo(() => monthRecords.filter(r=>r.type==="expense").reduce((s,r)=>s+parseFloat(r.amount||0),0), [monthRecords]);
  const balance = totalIncome - totalExpense;

  // กราฟรายจ่ายแยกหมวด
  const expenseByCategory = useMemo(() => {
    const map = {};
    monthRecords.filter(r=>r.type==="expense").forEach(r => {
      map[r.category] = (map[r.category]||0) + parseFloat(r.amount||0);
    });
    return Object.entries(map).sort((a,b)=>b[1]-a[1]);
  }, [monthRecords]);

  // กราฟรายวัน (14 วันล่าสุดของเดือน)
  const dailyData = useMemo(() => {
    const map = {};
    monthRecords.forEach(r => {
      const d = r.date;
      if(!map[d]) map[d] = {income:0, expense:0};
      if(r.type==="income") map[d].income+=parseFloat(r.amount||0);
      else map[d].expense+=parseFloat(r.amount||0);
    });
    return Object.entries(map).sort((a,b)=>a[0].localeCompare(b[0]));
  }, [monthRecords]);

  const handleChange = e => {
    const {name, value} = e.target;
    setForm(f => ({
      ...f,
      [name]: value,
      ...(name==="type" ? {category: value==="income" ? INCOME_CATS[0] : EXPENSE_CATS[0]} : {})
    }));
  };

  const handleSubmit = () => {
    if(!form.amount || !form.date) return;
    setRecords(rs => [{ ...form, id: Date.now() }, ...rs]);
    setForm(initialForm);
    setShowForm(false);
    showToast("✅ บันทึกแล้ว!");
  };

  const handleDelete = id => {
    if(confirm("ลบรายการนี้?")) { setRecords(rs => rs.filter(r=>r.id!==id)); showToast("🗑 ลบแล้ว"); }
  };

  const prevMonth = () => { if(viewMonth===0){setViewMonth(11);setViewYear(y=>y-1);}else setViewMonth(m=>m-1); };
  const nextMonth = () => { if(viewMonth===11){setViewMonth(0);setViewYear(y=>y+1);}else setViewMonth(m=>m+1); };

  const fmtNum = n => n.toLocaleString("th-TH", {minimumFractionDigits:2, maximumFractionDigits:2});
  const INPUT = { background:"#1a1a24", border:"1px solid #2d2d3d", borderRadius:8, color:"#e6edf3", padding:"10px 12px", fontSize:14, width:"100%", outline:"none" };

  const maxDaily = Math.max(...dailyData.map(([,v])=>Math.max(v.income,v.expense)), 1);

  return (
    <div style={{ minHeight:"100vh", background:"#0f0f14", paddingBottom:60 }}>
      {toast && <div style={{ position:"fixed", bottom:24, left:"50%", transform:"translateX(-50%)", background:"#238636", color:"#fff", padding:"10px 22px", borderRadius:10, fontSize:13, fontWeight:600, zIndex:99 }}>{toast}</div>}

      {/* Header */}
      <div style={{ background:"#1a1a24", borderBottom:"1px solid #2d2d3d", padding:"16px 20px", position:"sticky", top:0, zIndex:10 }}>
        <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between" }}>
          <div>
            <div style={{ fontWeight:700, fontSize:18 }}>💰 บัญชีรายรับรายจ่าย</div>
            <div style={{ color:"#8b949e", fontSize:12, marginTop:2 }}>{records.length} รายการทั้งหมด</div>
          </div>
          <button onClick={()=>{setShowForm(s=>!s);setForm(initialForm);}} style={{ background:showForm?"#30363d":"#238636", border:"none", borderRadius:10, color:"#fff", padding:"10px 18px", fontSize:13, fontWeight:600, cursor:"pointer" }}>
            {showForm ? "✕ ปิด" : "+ เพิ่ม"}
          </button>
        </div>

        {/* Month Navigator */}
        <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginTop:14, background:"#0f0f14", borderRadius:10, padding:"10px 16px" }}>
          <button onClick={prevMonth} style={{ background:"none", border:"none", color:"#e6edf3", fontSize:20, cursor:"pointer" }}>‹</button>
          <div style={{ fontWeight:600, fontSize:15 }}>{MONTHS_TH[viewMonth]} {viewYear+543}</div>
          <button onClick={nextMonth} style={{ background:"none", border:"none", color:"#e6edf3", fontSize:20, cursor:"pointer" }}>›</button>
        </div>
      </div>

      {/* Add Form */}
      {showForm && (
        <div style={{ background:"#1a1a24", borderBottom:"1px solid #2d2d3d", padding:"16px 20px" }}>
          <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:10, marginBottom:10 }}>
            <div>
              <div style={{ color:"#8b949e", fontSize:11, marginBottom:4 }}>ประเภท</div>
              <select name="type" value={form.type} onChange={handleChange} style={INPUT}>
                <option value="income">💚 รายรับ</option>
                <option value="expense">❤️ รายจ่าย</option>
              </select>
            </div>
            <div>
              <div style={{ color:"#8b949e", fontSize:11, marginBottom:4 }}>วันที่</div>
              <input name="date" type="date" value={form.date} onChange={handleChange} style={INPUT}/>
            </div>
            <div>
              <div style={{ color:"#8b949e", fontSize:11, marginBottom:4 }}>หมวดหมู่</div>
              <select name="category" value={form.category} onChange={handleChange} style={INPUT}>
                {(form.type==="income"?INCOME_CATS:EXPENSE_CATS).map(c=><option key={c}>{c}</option>)}
              </select>
            </div>
            <div>
              <div style={{ color:"#8b949e", fontSize:11, marginBottom:4 }}>จำนวนเงิน (บาท)</div>
              <input name="amount" type="number" value={form.amount} onChange={handleChange} placeholder="0.00" style={INPUT}/>
            </div>
          </div>
          <div style={{ marginBottom:10 }}>
            <div style={{ color:"#8b949e", fontSize:11, marginBottom:4 }}>หมายเหตุ</div>
            <input name="note" value={form.note} onChange={handleChange} placeholder="รายละเอียด..." style={INPUT}/>
          </div>
          <button onClick={handleSubmit} style={{ background:"#238636", border:"none", borderRadius:8, color:"#fff", padding:"11px 0", fontSize:14, fontWeight:600, cursor:"pointer", width:"100%" }}>
            บันทึก
          </button>
        </div>
      )}

      {/* Summary Cards */}
      <div style={{ padding:"16px 20px 0" }}>
        <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr 1fr", gap:10, marginBottom:16 }}>
          {[
            {label:"รายรับ", value:totalIncome, color:"#3fb950", icon:"💚"},
            {label:"รายจ่าย", value:totalExpense, color:"#f85149", icon:"❤️"},
            {label:"คงเหลือ", value:balance, color:balance>=0?"#3fb950":"#f85149", icon:"💰"},
          ].map(card=>(
            <div key={card.label} style={{ background:"#1a1a24", border:"1px solid #2d2d3d", borderRadius:10, padding:"12px 10px", textAlign:"center" }}>
              <div style={{ fontSize:10, color:"#8b949e", textTransform:"uppercase", marginBottom:4 }}>{card.label}</div>
              <div style={{ fontSize:15, fontWeight:700, color:card.color, fontFamily:"monospace" }}>
                {fmtNum(card.value)}
              </div>
            </div>
          ))}
        </div>

        {/* Tabs */}
        <div style={{ display:"flex", borderBottom:"1px solid #2d2d3d", marginBottom:16 }}>
          {["list","chart"].map(t=>(
            <button key={t} onClick={()=>setTab(t)} style={{ background:"none", border:"none", padding:"10px 16px 9px", color:tab===t?"#e6edf3":"#8b949e", borderBottom:tab===t?"2px solid #f78166":"2px solid transparent", fontWeight:tab===t?600:400, cursor:"pointer", fontSize:13 }}>
              {t==="list"?"📋 รายการ":"📊 กราฟ"}
            </button>
          ))}
        </div>

        {/* List */}
        {tab==="list" && (
          monthRecords.length===0
            ? <div style={{ textAlign:"center", color:"#8b949e", padding:"60px 0" }}>
                <div style={{ fontSize:40, marginBottom:12 }}>📭</div>
                <div>ยังไม่มีรายการในเดือนนี้</div>
              </div>
            : <div style={{ display:"flex", flexDirection:"column", gap:8 }}>
                {monthRecords.map(r=>(
                  <div key={r.id} style={{ background:"#1a1a24", border:`1px solid ${r.type==="income"?"rgba(63,185,80,0.3)":"rgba(248,81,73,0.3)"}`, borderRadius:10, padding:"12px 14px", display:"flex", alignItems:"center", gap:12 }}>
                    <div style={{ fontSize:22 }}>{r.type==="income"?"💚":"❤️"}</div>
                    <div style={{ flex:1 }}>
                      <div style={{ fontWeight:600, fontSize:14 }}>{r.category}</div>
                      <div style={{ color:"#8b949e", fontSize:12, marginTop:2 }}>{r.date}{r.note?` · ${r.note}`:""}</div>
                    </div>
                    <div style={{ fontWeight:700, fontSize:16, color:r.type==="income"?"#3fb950":"#f85149" }}>
                      {r.type==="income"?"+":"-"}{fmtNum(parseFloat(r.amount))}
                    </div>
                    <button onClick={()=>handleDelete(r.id)} style={{ background:"none", border:"none", color:"#f85149", cursor:"pointer", fontSize:16, padding:"4px" }}>🗑</button>
                  </div>
                ))}
              </div>
        )}

        {/* Chart */}
        {tab==="chart" && (
          <div>
            {/* รายจ่ายแยกหมวด */}
            {expenseByCategory.length > 0 && (
              <div style={{ background:"#1a1a24", border:"1px solid #2d2d3d", borderRadius:10, padding:16, marginBottom:14 }}>
                <div style={{ color:"#8b949e", fontSize:12, marginBottom:12, textTransform:"uppercase" }}>❤️ รายจ่ายแยกหมวด</div>
                {expenseByCategory.map(([cat, amt])=>(
                  <div key={cat} style={{ marginBottom:10 }}>
                    <div style={{ display:"flex", justifyContent:"space-between", marginBottom:4 }}>
                      <span style={{ fontSize:13, color:"#e6edf3" }}>{cat}</span>
                      <span style={{ fontSize:13, fontWeight:600, color:"#f85149" }}>{fmtNum(amt)} ฿</span>
                    </div>
                    <div style={{ background:"#2d2d3d", borderRadius:4, height:8 }}>
                      <div style={{ width:`${(amt/totalExpense)*100}%`, background:"#f85149", height:"100%", borderRadius:4 }}/>
                    </div>
                  </div>
                ))}
              </div>
            )}

            {/* กราฟรายวัน */}
            {dailyData.length > 0 && (
              <div style={{ background:"#1a1a24", border:"1px solid #2d2d3d", borderRadius:10, padding:16, marginBottom:14 }}>
                <div style={{ color:"#8b949e", fontSize:12, marginBottom:12, textTransform:"uppercase" }}>📅 รายรับ-รายจ่ายรายวัน</div>
                <div style={{ display:"flex", alignItems:"flex-end", gap:6, height:100, overflowX:"auto", paddingBottom:4 }}>
                  {dailyData.map(([date, v])=>(
                    <div key={date} style={{ display:"flex", flexDirection:"column", alignItems:"center", gap:2, minWidth:32 }}>
                      <div style={{ display:"flex", gap:2, alignItems:"flex-end", height:80 }}>
                        <div style={{ width:10, background:"#3fb950", borderRadius:"3px 3px 0 0", height:`${(v.income/maxDaily)*76}px` }}/>
                        <div style={{ width:10, background:"#f85149", borderRadius:"3px 3px 0 0", height:`${(v.expense/maxDaily)*76}px` }}/>
                      </div>
                      <div style={{ color:"#8b949e", fontSize:9, textAlign:"center" }}>{date.slice(8)}</div>
                    </div>
                  ))}
                </div>
                <div style={{ display:"flex", gap:16, marginTop:8 }}>
                  <div style={{ display:"flex", alignItems:"center", gap:5 }}><div style={{ width:10,height:10,background:"#3fb950",borderRadius:2 }}/><span style={{ color:"#8b949e",fontSize:11 }}>รายรับ</span></div>
                  <div style={{ display:"flex", alignItems:"center", gap:5 }}><div style={{ width:10,height:10,background:"#f85149",borderRadius:2 }}/><span style={{ color:"#8b949e",fontSize:11 }}>รายจ่าย</span></div>
                </div>
              </div>
            )}

            {dailyData.length===0 && <div style={{ textAlign:"center", color:"#8b949e", padding:"40px 0" }}>เพิ่มรายการก่อนเพื่อดูกราฟ</div>}
          </div>
        )}
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
